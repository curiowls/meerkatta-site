# Paddle client-side tokens are publishable. Never put Paddle API keys or
# webhook secrets in VITE_* variables.
VITE_PADDLE_ENV=sandbox
VITE_PADDLE_SANDBOX_CLIENT_TOKEN=test_SANDBOX_CLIENT_TOKEN
VITE_PADDLE_PRODUCTION_CLIENT_TOKEN=live_PRODUCTION_CLIENT_TOKEN
VITE_PADDLE_PRICE_MONTHLY=pri_MONTHLY_PRICE_ID
VITE_PADDLE_PRICE_ANNUAL=pri_ANNUAL_PRICE_ID
VITE_PADDLE_PRICE_LIFETIME=pri_LIFETIME_PRICE_ID
VITE_PADDLE_LIFETIME_DISCOUNT_CODE=launch
